    "import numpy as np\n",
    "\n",
    "# Session intensity (kWh delivered per hour)\n",
    "feat_df['session_intensity'] = feat_df['energy_consumed_kwh'] / (feat_df['charging_duration'] / 60)\n",
    "\n",
    "# Rolling average station load (previous 5 sessions at the same station)\n",
    "feat_df['rolling_avg_station_load'] = (\n",
    "    feat_df.groupby('station_id')['station_load']\n",
    "           .transform(lambda x: x.shift(1).rolling(window=5, min_periods=1).mean())\n",
    ")\n",
    "feat_df['rolling_avg_station_load'] = feat_df['rolling_avg_station_load'].fillna(feat_df['station_load'])\n",
    "\n",
    "# Load delta\n",
    "feat_df['load_delta'] = feat_df['station_load'] - feat_df['rolling_avg_station_load']\n",
    "\n",
    "# Station utilization: concurrent active sessions at the same station at this session's start time\n",
    "feat_df['station_utilization'] = 0\n",
    "for station, group in feat_df.groupby('station_id'):\n",
    "    group = group.sort_values('charging_start_time')\n",
    "    starts = group['charging_start_time'].values\n",
    "    ends = group['charging_end_time'].values\n",
    "    idx = group.index.values\n",
    "    util = np.zeros(len(group), dtype=int)\n",
    "    for i in range(len(group)):\n",
    "        t = starts[i]\n",
    "        overlap = np.sum((starts <= t) & (ends > t)) - 1\n",
    "        util[i] = max(overlap, 0)\n",
    "    feat_df.loc[idx, 'station_utilization'] = util\n",
    "\n",
    "# A couple of simple time-based features while we're at it\n",
    "feat_df['hour_of_day'] = feat_df['charging_start_time'].dt.hour\n",
    "feat_df['is_weekend'] = feat_df['day_of_week'].isin(['Saturday', 'Sunday']).astype(int)\n",
    "\n",
    "new_feature_cols = ['session_intensity', 'rolling_avg_station_load', 'load_delta',\n",
    "                     'station_utilization', 'hour_of_day', 'is_weekend']\n",
    "feat_df[new_feature_cols].describe().round(2)\n"
   ]
  },
